{
  "name": "meetcap-recorder-main",
  "version": "0.1.0",
  "description": "Main-process setup for meetcap recording: macOS loopback flags + save-recording + media-access IPC. Electron.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paul-leo/zoom-record-demo.git",
    "directory": "packages/recorder-main"
  },
  "keywords": ["electron", "audio", "recorder", "loopback", "system-audio", "meetcap"],
  "dependencies": {
    "meetcap-core": "workspace:*",
    "electron-audio-loopback": "^1.0.6"
  },
  "peerDependencies": {
    "electron": ">=31 <39"
  },
  "peerDependenciesMeta": {
    "electron": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "38.2.2",
    "typescript": "^5.6.3"
  }
}
