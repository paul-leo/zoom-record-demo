{
  "name": "meetcap-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "meetcap — detect meeting apps and record both sides of the audio in Electron",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "demo": "pnpm --filter electron-demo start",
    "dist:app": "turbo build && pnpm --filter electron-demo dist",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && bash scripts/release-publish.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
