{
  "name": "electron-demo",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end demo: detect a meeting → record mic + system audio → save. Consumes meetcap-* packages.",
  "author": "meetcap",
  "main": "main.js",
  "scripts": {
    "build": "esbuild renderer/app.ts --bundle --outfile=renderer/bundle.js --platform=browser --format=iife --sourcemap --define:__HARNESS_ENABLED__=true",
    "build:dist": "esbuild renderer/app.ts --bundle --outfile=renderer/bundle.js --platform=browser --format=iife --define:__HARNESS_ENABLED__=false",
    "start": "npm run build && electron .",
    "dist": "npm run build:dist && electron-builder --mac dmg",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "meetcap-core": "workspace:*",
    "meetcap-main": "workspace:*",
    "meetcap-renderer": "workspace:*"
  },
  "devDependencies": {
    "@harness-fe/runtime": "^4.1.0",
    "@types/node": "^22.10.2",
    "electron": "38.2.2",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
