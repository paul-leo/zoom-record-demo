{
  "name": "electron-demo",
  "version": "0.0.0",
  "private": true,
  "description": "End-to-end demo: detect a meeting → record mic + system audio → save. Consumes meetcap-* packages.",
  "main": "main.js",
  "scripts": {
    "build": "esbuild renderer/app.ts --bundle --outfile=renderer/bundle.js --platform=browser --format=iife --sourcemap",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "meetcap-core": "workspace:*",
    "meetcap-detector": "workspace:*",
    "meetcap-recorder": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "38.2.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
